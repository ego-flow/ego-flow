flowchart TD

    Start["사용자가 앱에서 Start Streaming<br/>StreamViewModel.kt::startStream"] --> Login["앱이 backend 로그인<br/>EgoFlowBackendClient.kt::login<br/>(독립 클라이언트: EgoFlowAuthClient.kt::login)"]
    Login --> Register["POST /api/v1/streams/register<br/>EgoFlowBackendClient.kt::registerStreamSession<br/>(독립 클라이언트: EgoFlowStreamClient.kt::registerStream)"]

    subgraph RegisterFlow[등록과 예약 생성]
        Register --> AccessCheck["repository maintain 권한 확인<br/>repo-access.middleware.ts::repoAccess<br/>repository.service.ts::assertRepositoryAccess"]
        AccessCheck --> PathCheck["repository path 사용 가능 여부 확인<br/>stream.service.ts::ensureRepositoryPathIsAvailable"]
        PathCheck --> CreatePending["RecordingSession 생성<br/>recording-session.service.ts::createSession"]
        CreatePending --> PendingState["상태 PENDING<br/>recording-session.service.ts::createSession"]
        PendingState --> WritePendingRedis["Redis live pointer 저장<br/>recording-session.service.ts::createSession"]
        WritePendingRedis --> ReturnRegister["recording_session_id + rtmp_url + status ready 반환<br/>stream.service.ts::registerSession"]
    end

    ReturnRegister --> Publish["앱이 RTMP publish 시작<br/>StreamViewModel.kt::startRtmpTransport<br/>RtmpStreamer.kt::start<br/>RtmpPublisher.kt::connect"]

    subgraph PublishAuth[RTMP publish 인증]
        Publish --> RtmpAuth["MediaMTX -> POST /api/v1/auth/rtmp<br/>mediamtx.yml::authHTTPAddress<br/>auth.routes.ts::POST /rtmp"]
        RtmpAuth --> VerifyJwt["JWT 검증 및 활성 사용자 확인<br/>auth.service.ts::verifyRtmpAuthorization"]
        VerifyJwt --> LookupLivePath["Redis path pointer 조회<br/>stream.service.ts::findLiveSessionByStreamPath<br/>recording-session.service.ts::getLiveCacheByPath"]
        LookupLivePath --> MatchOwner{"토큰 사용자와 recording 사용자 일치<br/>auth.service.ts::verifyRtmpAuthorization"}
        MatchOwner -->|아니오| RejectPublish["401 거부<br/>auth.routes.ts::POST /rtmp"]
        MatchOwner -->|예| ExtendTtl["PENDING live pointer TTL 연장<br/>stream.service.ts::activateSession<br/>recording-session.service.ts::promoteLivePointerTtl"]
        ExtendTtl --> AllowPublish["200 허용<br/>auth.routes.ts::POST /rtmp"]
    end

    AllowPublish --> StreamReadyHook["MediaMTX -> stream-ready hook<br/>mediamtx.yml::runOnReady<br/>stream-ready-wrapper.sh"]

    subgraph ReadyFlow[실제 송출 시작 확정]
        StreamReadyHook --> ResolveReadySession["path(Redis) 또는 path+query(DB) 기준 session 조회<br/>hooks.routes.ts::POST /stream-ready<br/>recording-session.service.ts::resolveRecordingSessionIdForReady"]
        ResolveReadySession --> PromoteStreaming["RecordingSession 상태를 STREAMING 으로 전환<br/>recording-session.service.ts::handleStreamReady"]
        PromoteStreaming --> SaveSource["sourceId sourceType readyAt 저장<br/>recording-session.service.ts::handleStreamReady"]
        SaveSource --> RefreshLiveRedis["Redis repo path source pointer 갱신<br/>recording-session.service.ts::handleStreamReady"]
    end

    RefreshLiveRedis --> LiveStreaming["실시간 송출 진행<br/>RtmpStreamer.kt::sendGlassesFrame/sendBitmapFrame"]

    subgraph ActiveAndPlayback[active 조회와 playback]
        LiveStreaming --> ActiveQuery["GET /api/v1/streams/active<br/>frontend live.tsx::requestActiveStreams<br/>frontend api/streams.ts::requestActiveStreams"]
        ActiveQuery --> LoadStreamingFromDb["DB에서 STREAMING 세션 조회<br/>stream.service.ts::listActiveSessions"]
        LoadStreamingFromDb --> FilterAccess["repository read 권한 필터<br/>stream.service.ts::listActiveSessions<br/>repository.service.ts::getRepositoryAccess"]
        FilterAccess --> FilterActivePath["MediaMTX active path 와 교집합<br/>stream.service.ts::getActiveRepositoryNames"]
        FilterActivePath --> ReturnActive["hls_url 포함 active stream 반환<br/>stream.service.ts::listActiveSessions"]
        ReturnActive --> Playback["대시보드가 HLS 재생<br/>frontend live.tsx::LivePage<br/>frontend HlsPlayer.tsx"]
        Playback --> ReadAuth["MediaMTX read playback auth<br/>mediamtx.yml::authHTTPAddress<br/>auth.routes.ts::POST /rtmp"]
        ReadAuth --> CheckPlaybackAccess["repository read 권한 확인<br/>auth.service.ts::verifyRtmpAuthorization"]
        CheckPlaybackAccess --> PlaybackAllowed["재생 허용 또는 거부<br/>auth.routes.ts::POST /rtmp"]
    end

    LiveStreaming --> SegmentCreateHook["MediaMTX -> recording-segment-create hook<br/>mediamtx.yml::runOnRecordSegmentCreate<br/>segment-create-wrapper.sh"]
    SegmentCreateHook --> CreateSegment["RecordingSegment 생성 또는 upsert<br/>hooks.routes.ts::POST /recording-segment-create<br/>recording-session.service.ts::handleSegmentCreate"]
    CreateSegment --> WritingSegment["segment 상태 WRITING<br/>recording-session.service.ts::handleSegmentCreate"]

    LiveStreaming --> SegmentCompleteHook["MediaMTX -> recording-segment-complete hook<br/>mediamtx.yml::runOnRecordSegmentComplete<br/>segment-complete-wrapper.sh"]
    SegmentCompleteHook --> CompleteSegment["RecordingSegment 상태 COMPLETED<br/>hooks.routes.ts::POST /recording-segment-complete<br/>recording-session.service.ts::handleSegmentComplete"]
    CompleteSegment --> MaybeFinalize{"RecordingSession 이 FINALIZING 인가<br/>recording-session.service.ts::handleSegmentComplete"}
    MaybeFinalize -->|예| RetryFinalize["finalize enqueue 재시도<br/>recording-session.service.ts::tryEnqueueFinalize"]
    MaybeFinalize -->|아니오| KeepStreaming["계속 recording<br/>recording-session.service.ts::handleSegmentComplete"]

    LiveStreaming --> StopDecision{"어떻게 종료되는가<br/>StreamViewModel.kt::stopStream<br/>recording-session.service.ts::handleStreamNotReady/reconcileSessions"}

    subgraph StopRequest[명시적 종료]
        StopDecision -->|앱 Stop 버튼| UserStop["POST /api/v1/recordings/:id/stop reason USER_STOP<br/>StreamViewModel.kt::stopStream<br/>EgoFlowBackendClient.kt::stopStreamSession"]
        StopDecision -->|glasses 촬영 종료| GlassesStop["POST /api/v1/recordings/:id/stop reason GLASSES_STOP<br/>StreamViewModel.kt::stopStream<br/>EgoFlowBackendClient.kt::stopStreamSession"]
        UserStop --> CheckStopAccess["repository maintain 권한 확인<br/>recordings.routes.ts<br/>repository.service.ts::assertRepositoryAccess"]
        GlassesStop --> CheckStopAccess
        CheckStopAccess --> MarkStopRequested["RecordingSession 상태 STOP_REQUESTED<br/>recording-session.service.ts::requestStop"]
        MarkStopRequested --> SaveStopMeta["endReason stopRequestedAt 기록<br/>recording-session.service.ts::requestStop"]
        SaveStopMeta --> UpdateLiveCache["Redis live cache status 갱신<br/>recording-session.service.ts::requestStop"]
    end

    subgraph UnexpectedDisconnect[비정상 종료]
        StopDecision -->|네트워크 단절 앱 크래시 RTMP 끊김| NotReadyHook["MediaMTX -> stream-not-ready hook<br/>mediamtx.yml::runOnNotReady<br/>stream-not-ready-wrapper.sh"]
        StopDecision -->|hook 누락 또는 상태 꼬임| ReconcileTick["reconcile loop<br/>index.ts::start<br/>stream.service.ts::startReconcileLoop"]
        ReconcileTick --> ReconcileCheck["DB 상태와 MediaMTX active path 대조<br/>recording-session.service.ts::reconcileSessions"]
        ReconcileCheck --> PendingTimeout{"PENDING timeout 인가<br/>recording-session.service.ts::reconcileSessions"}
        PendingTimeout -->|예| AbortPending["ABORTED + REGISTRATION_TIMEOUT<br/>recording-session.service.ts::reconcileSessions"]
        PendingTimeout -->|아니오| MissingPublisher{"STREAMING 또는 STOP_REQUESTED 인데 path 없음<br/>recording-session.service.ts::reconcileSessions"}
        MissingPublisher -->|예| ReconcileFinalize["FINALIZING 전환<br/>recording-session.service.ts::reconcileSessions"]
    end

    UpdateLiveCache --> NotReadyHook

    subgraph NotReadyAndFinalize[실제 송출 종료 후 마무리]
        NotReadyHook --> ResolveNotReady["sourceId path DB fallback 으로 session 조회<br/>recording-session.service.ts::handleStreamNotReady"]
        ResolveNotReady --> FinalizingState["RecordingSession 상태 FINALIZING<br/>recording-session.service.ts::handleStreamNotReady"]
        FinalizingState --> SaveNotReady["notReadyAt 기록<br/>recording-session.service.ts::handleStreamNotReady"]
        SaveNotReady --> ClearLivePointers["Redis repo path source pointer 삭제<br/>recording-session.service.ts::clearLivePointers"]
        ClearLivePointers --> TryFinalize["tryEnqueueFinalize 실행<br/>recording-session.service.ts::tryEnqueueFinalize"]
        ReconcileFinalize --> TryFinalize
        RetryFinalize --> TryFinalize
        AbortPending --> EndWithoutVideo(["publish 되지 못한 예약 종료<br/>recording-session.service.ts::reconcileSessions"])
    end

    subgraph FinalizeRules[finalize enqueue 조건]
        TryFinalize --> WritingSegments{"WRITING segment 존재<br/>recording-session.service.ts::tryEnqueueFinalize"}
        WritingSegments -->|있음 max wait 이전| WaitFlush["마지막 flush 대기<br/>recording-session.service.ts::tryEnqueueFinalize"]
        WritingSegments -->|있음 max wait 초과| FailFlushTimeout["FAILED<br/>recording-session.service.ts::markSessionFailed"]
        WritingSegments -->|없음| CompletedSegments{"COMPLETED segment 존재<br/>recording-session.service.ts::tryEnqueueFinalize"}
        CompletedSegments -->|없음 grace 이전| WaitMore["FINALIZING 유지 후 재시도<br/>recording-session.service.ts::tryEnqueueFinalize"]
        CompletedSegments -->|없음 grace 초과| FailNoSegment["FAILED<br/>recording-session.service.ts::markSessionFailed"]
        CompletedSegments -->|있음| UpsertVideo["Video 레코드 upsert (PENDING)<br/>recording-session.service.ts::tryEnqueueFinalize"]
        UpsertVideo --> EnqueueFinalize["recording-finalize job enqueue<br/>processing.service.ts::enqueueRecordingFinalize"]
    end

    subgraph WorkerFlow[최종 video 생성]
        EnqueueFinalize --> LoadRecording["worker가 RecordingSession 과 Segment 조회<br/>recording-finalize.worker.ts::processRecordingFinalize"]
        LoadRecording --> SegmentCount{"COMPLETED segment 개수<br/>recording-finalize.worker.ts::processRecordingFinalize"}
        SegmentCount -->|1개| UseSingleRaw["단일 raw 사용<br/>recording-finalize.worker.ts::processRecordingFinalize"]
        SegmentCount -->|2개 이상| MergeSegments["segment 병합<br/>recording-finalize.worker.ts::processRecordingFinalize<br/>encoding.ts::concatSegments"]
        UseSingleRaw --> EncodeVideo["기존 인코딩 파이프라인 실행<br/>encoding.ts::encodeVlmVideo<br/>encoding.ts::encodeDashboardVideo<br/>encoding.ts::encodeThumbnail"]
        MergeSegments --> EncodeVideo
        EncodeVideo --> SaveVideo["Video 1개 생성 또는 업데이트<br/>recording-finalize.worker.ts::processRecordingFinalize"]
        SaveVideo --> MarkCompleted["RecordingSession 상태 COMPLETED<br/>recording-finalize.worker.ts::processRecordingFinalize"]
    end

    FailNoSegment --> FailedEnd(["recording 실패 종료<br/>recording-session.service.ts::markSessionFailed"])
    FailFlushTimeout --> FailedEnd
    MarkCompleted --> CompletedEnd(["RecordingSession 1개 -> Final Video 1개<br/>recording-finalize.worker.ts::processRecordingFinalize"])
