POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-postgres-password
POSTGRES_DB=egoflow
JWT_SECRET=change-this-jwt-secret-with-at-least-16-characters
ADMIN_DEFAULT_PASSWORD=change-this-admin-password
CORS_ORIGIN=http://YOUR_SERVER_IP:8088
PUBLIC_RTMP_BASE_URL=rtmp://YOUR_SERVER_IP:1935/live
PUBLIC_HLS_BASE_URL=http://YOUR_SERVER_IP:8888
WORKER_CONCURRENCY=2
DELETE_RAW_AFTER_PROCESSING=true
BACKEND_IMAGE=ghcr.io/ego-flow/ego-flow-backend:main
DASHBOARD_IMAGE=ghcr.io/ego-flow/ego-flow-dashboard:main
DATA_ROOT=/opt/egoflow/data
